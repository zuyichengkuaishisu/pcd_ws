# Web page port on the host machine.
APP_PORT=4174

# M20 robot TCP endpoint.
M20_ROBOT_HOST=10.21.31.103
M20_ROBOT_PORT=30001

# M20 mapping UDP gateway endpoint.
M20_MAPPING_HOST=10.21.31.106
M20_MAPPING_PORT=30100

# Default built-in map asset directory name under /app/data/maps.
M20_DEFAULT_MAP_ASSET_NAME=siteB-20260616-105415

# Use a mirror for the Node base image when Docker Hub is slow or blocked.
NODE_IMAGE=docker.m.daocloud.io/library/node:24-bookworm-slim

# Optional: multiple robots.
# Keep it in a single line if you enable it.
# M20_MULTI_ROBOTS=[{"id":"robot-a","name":"Robot A","host":"10.21.31.103","port":30001,"color":"#22c55e"},{"id":"robot-b","name":"Robot B","host":"10.21.31.104","port":30001,"color":"#38bdf8"}]
